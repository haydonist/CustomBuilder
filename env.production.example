# Production Mode (PostgreSQL)
# Copy this to .env.production for production deployment

# PostgreSQL Database URL
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# Example providers:
# Railway: postgresql://postgres:password@containers-us-west-xxx.railway.app:5432/railway
# Supabase: postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
# Heroku: postgresql://user:password@ec2-xxx.compute-1.amazonaws.com:5432/database

# Shopify configuration (from Partner Dashboard)
SHOPIFY_API_KEY=your_production_api_key
SHOPIFY_API_SECRET=your_production_api_secret
SCOPES=write_products
