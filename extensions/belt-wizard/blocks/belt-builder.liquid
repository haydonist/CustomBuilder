{% comment %}
  Belt Builder App Block
  This block embeds the BeltMaster belt customization wizard into any page
{% endcomment %}

<div class="belt-builder">
  {% render 'belt-wizard-styles' %}
  <belt-wizard
    sizing-chart-src="{{ 'belts/sizing-chart.png' | asset_url }}"
    looped-belt-src="{{ 'belts/looped-belt.png' | asset_url }}"
  ></belt-wizard>
  <div id="scrollToken" style="height: 1px;"></div>
</div>

{{ 'belt-wizard.css' | asset_url | stylesheet_tag }}
<script src="{{ 'belt-wizard.js' | asset_url }}" defer></script>

<script>
  console.log('[Belt Wizard] Script loaded');
  document.addEventListener('DOMContentLoaded', function() {
    
    // Check if web component is defined
    if (customElements.get('belt-wizard')) {
      console.log('[Belt Wizard] Web component is registered');
    } else {
      console.error('[Belt Wizard] Web component NOT registered');
    }
    
    // Force remove padding from all parent containers
    const section = document.querySelector('.belt-builder');
    if (section) {
      let parent = section.parentElement;
      let depth = 0;
      while (parent && depth < 10) {
        parent.style.paddingLeft = '0';
        parent.style.paddingRight = '0';
        parent.style.marginLeft = '0';
        parent.style.marginRight = '0';
        parent.style.maxWidth = 'none';
        console.log('[Belt Wizard] Removed padding from parent:', parent.className || parent.tagName);
        parent = parent.parentElement;
        depth++;
      }
    }
  });
</script>

<style>
  .belt-builder {
    min-height: 80vh;
    display: flex;
    flex-direction: column;
    background-color: #291c12;
    color: #fff;
    
    /* Force full width by breaking out of container */
    width: 100vw;
    margin-left: 0;
    margin-right: 0;
    padding: 0;
    max-width: none;
    box-sizing: border-box;
  }
  
  belt-wizard {
    flex-grow: 1;
    background-color: #291c12;
  }

</style>

{% schema %}
{
  "name": "Belt Builder",
  "target": "section",
  "tag": "section",
  "class": "belt-builder-section-wrapper",
  "stylesheet": "belt-wizard.css"
}
{% endschema %}
