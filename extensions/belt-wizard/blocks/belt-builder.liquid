{% comment %}
  Belt Builder App Block
  Reads its appearance + content from the shop metafield
  `custom_belt_builder.settings` written by the app admin.
{% endcomment %}

{% liquid
  assign s = shop.metafields.custom_belt_builder.settings.value

  assign bg_color                  = s.backgroundColor             | default: '#291c12'
  assign text_color                = s.fontColor                   | default: '#ffffff'
  assign font_family               = s.fontFamily                  | default: 'Arial, sans-serif'
  assign stepper_line              = s.stepperLineColor            | default: '#ffffff'
  assign stepper_incomplete        = s.stepperDotIncompleteColor   | default: '#808080'
  assign stepper_complete          = s.stepperDotCompleteColor     | default: '#476fff'
  assign stepper_current           = s.stepperDotCurrentColor      | default: '#476fff'
  assign base_order                = s.baseCollectionOrder
  assign buckle_order              = s.buckleCollectionOrder
  assign loop_order                = s.loopCollectionOrder
  assign concho_order              = s.conchoCollectionOrder
  assign tip_order                 = s.tipCollectionOrder
  assign concho_recommendation     = s.conchoRecommendationText    | default: '<p><strong>Our Recommendation:</strong> Using the same concho in sets of 5, 7, or 9 usually looks best and qualifies for a discount. Other quantities or mixing different conchos can end up looking unpolished.</p>'
  assign checkout_policy           = s.checkoutPolicyText          | default: '<p>Free cancellation is available within 24 business hours of placing your order. After an order is placed, our team will contact you to confirm all order details.</p><p>Each belt is custom-tailored to your specifications. Because custom belts cannot be reused or resold, a <strong>30% restocking fee</strong> will apply if a return is requested after the order has been completed.</p>'
%}

<div
  class="belt-builder"
  style="--belt-wizard-background-color: {{ bg_color }}; --belt-wizard-bg-color: {{ bg_color }}; --belt-wizard-text-color-custom: {{ text_color }}; --belt-wizard-font-family-custom: {{ font_family }}; --stepper-line-color-custom: {{ stepper_line }}; --stepper-dot-incomplete-color-custom: {{ stepper_incomplete }}; --stepper-dot-complete-color-custom: {{ stepper_complete }}; --stepper-dot-current-color-custom: {{ stepper_current }};"
>
  {% render 'belt-wizard-styles' %}
  <belt-wizard
    looped-belt-src="{{ 'belts/looped-belt.png' | asset_url }}"
    concho-recommendation="{{ concho_recommendation }}"
    checkout-policy="{{ checkout_policy }}"
    {% if base_order != blank %}collection-order-base="{{ base_order }}"{% endif %}
    {% if buckle_order != blank %}collection-order-buckle="{{ buckle_order }}"{% endif %}
    {% if loop_order != blank %}collection-order-loops="{{ loop_order }}"{% endif %}
    {% if concho_order != blank %}collection-order-conchos="{{ concho_order }}"{% endif %}
    {% if tip_order != blank %}collection-order-tip="{{ tip_order }}"{% endif %}
  ></belt-wizard>
  <div id="scrollToken" style="height: 1px;"></div>
</div>

{{ 'belt-wizard.css' | asset_url | stylesheet_tag }}
<script src="{{ 'belt-wizard.js' | asset_url }}" defer></script>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    document.documentElement.style.setProperty('--belt-wizard-bg-color', {{ bg_color | json }});
    document.documentElement.style.setProperty('--belt-wizard-background-color', {{ bg_color | json }});
    document.documentElement.style.setProperty('--belt-wizard-text-color-custom', {{ text_color | json }});
    document.documentElement.style.setProperty('--belt-wizard-font-family-custom', {{ font_family | json }});
    document.documentElement.style.setProperty('--stepper-line-color-custom', {{ stepper_line | json }});
    document.documentElement.style.setProperty('--stepper-dot-incomplete-color-custom', {{ stepper_incomplete | json }});
    document.documentElement.style.setProperty('--stepper-dot-complete-color-custom', {{ stepper_complete | json }});
    document.documentElement.style.setProperty('--stepper-dot-current-color-custom', {{ stepper_current | json }});
  });
</script>

<style>
  .belt-builder {
    min-height: 80vh;
    display: flex;
    flex-direction: column;
    color: var(--belt-wizard-text-color-custom, #fff);
    font-family: var(--belt-wizard-font-family-custom, inherit);
    width: 100%;
    margin-left: 0;
    margin-right: 0;
    padding: 0 1rem;
    max-width: none;
    box-sizing: border-box;
  }

  belt-wizard {
    flex-grow: 1;
    min-width: 0;
    max-width: 100%;
  }
</style>

{% schema %}
{
  "name": "Belt Builder",
  "target": "section",
  "tag": "section",
  "class": "belt-builder-section-wrapper",
  "stylesheet": "belt-wizard.css",
  "settings": []
}
{% endschema %}
