# ===========================================
# ENVIRONMENT CONFIGURATION
# ===========================================
# Choose ONE of the following configurations:

# --- LOCAL DEVELOPMENT (SQLite) ---
# Uncomment for local development:
DATABASE_URL="file:./dev.sqlite"

# --- PRODUCTION (PostgreSQL) ---
# Uncomment for production and replace with your database URL:
# DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# Example providers:
# Railway:  postgresql://postgres:password@containers-us-west-xxx.railway.app:5432/railway
# Supabase: postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
# Heroku:   postgresql://user:password@ec2-xxx.compute-1.amazonaws.com:5432/database

# ===========================================
# SHOPIFY CONFIGURATION
# ===========================================
# Auto-managed by Shopify CLI in development
# Set manually in production hosting platform

SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
SCOPES=write_products
