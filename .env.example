# Copy to .env on the server and fill in real values. Do not commit .env.

# --- Shopify ---
# From your app in the Shopify Partner dashboard
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
# Comma-separated, must match shopify.app.toml access_scopes
SCOPES=write_products,write_files,write_inventory,write_publications
# Public HTTPS URL where nginx serves this app
SHOPIFY_APP_URL=https://belts.example.com

# --- Database (used by both the app container and the postgres container) ---
POSTGRES_USER=beltbuilder
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=beltbuilder
DATABASE_URL=postgresql://beltbuilder:change-me-to-a-long-random-string@db:5432/beltbuilder?schema=public

# --- App ---
NODE_ENV=production
PORT=3000
